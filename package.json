{
  "name": "pantheon-guard",
  "version": "0.4.2",
  "description": "Deterministic conscience layer for AI agent output. Catches manipulative copy, false urgency, and dark patterns — the content-safety failure mode missed by input-attack guardrails.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "examples",
    "docs",
    "bench",
    "README.md",
    "README.ru.md",
    "PITCH.md",
    "CHANGELOG.md",
    "LICENSE-MIT.md",
    "LICENSE-COMMERCIAL.md"
  ],
  "scripts": {
    "demo": "node examples/cli-demo.js",
    "test": "node --test test/*.test.js",
    "bench:freeze": "node bench/freeze-baseline.js",
    "bench:check": "node bench/check.js",
    "bench:split": "node bench/holdout.js",
    "bench:annotate2": "node bench/annotator2.js",
    "bench:kappa": "node bench/kappa.js",
    "build": "tsup",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "ai-safety",
    "guardrails",
    "llm",
    "responsible-ai",
    "agents",
    "manipulation-detection",
    "dark-patterns",
    "marketing-ethics",
    "nemo-guardrails"
  ],
  "author": {
    "name": "Aleksandr Baryshnikov",
    "email": "alkanfel1987@gmail.com",
    "url": "https://github.com/alkanfel1987"
  },
  "license": "SEE LICENSE IN LICENSE-MIT.md AND LICENSE-COMMERCIAL.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alkanfel1987/pantheon-guard.git"
  },
  "homepage": "https://github.com/alkanfel1987/pantheon-guard#readme",
  "bugs": {
    "url": "https://github.com/alkanfel1987/pantheon-guard/issues",
    "email": "alkanfel1987@gmail.com"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
